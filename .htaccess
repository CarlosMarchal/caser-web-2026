Options -Indexes
RewriteEngine On

# -----------------------------------------------
# 1. Redirigir URLs con .html a URLs limpias (301)
# -----------------------------------------------
# Excluir index.html (la raíz ya es limpia)
RewriteCond %{THE_REQUEST} \s/index\.html[\s?] [NC]
RewriteRule ^ / [R=301,L]

# Redirigir cualquier otra página con .html a /slug/
RewriteCond %{THE_REQUEST} \s/([^/]+)\.html[\s?] [NC]
RewriteRule ^ /%1/ [R=301,L]

# -----------------------------------------------
# 2. Servir /slug/ internamente desde slug.html
# -----------------------------------------------
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^([^/]+)/$ $1.html [L]

# -----------------------------------------------
# 3. Seguridad: bloquear acceso a archivos ocultos
# -----------------------------------------------
RewriteRule ^\.htaccess$ - [F,L]
