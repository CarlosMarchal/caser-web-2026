Options -Indexes

RewriteEngine On

# Forzar HTTPS (301 permanente)
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# Redirigir www → non-www (301 permanente)
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^ https://%1%{REQUEST_URI} [R=301,L]

# Forzar trailing slash en URLs de subpáginas (301 permanente)
# /particulares → /particulares/  (consolida señal SEO en una sola URL)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} !/$
RewriteCond %{REQUEST_URI} !\.
RewriteRule ^(.+)$ /$1/ [R=301,L]

# Redirigir /pagina/ → pagina.html (internal rewrite, sin cambiar URL)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^([^.]+?)/?$ $1.html [L]
